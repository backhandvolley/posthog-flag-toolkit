{
  "name": "posthog-flag-toolkit",
  "version": "0.1.0",
  "description": "Type-safe feature flag registry, sync, release tracking, and auto-rollback guardian for PostHog",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./adapters/inngest": {
      "import": {
        "types": "./dist/adapters/inngest.d.ts",
        "default": "./dist/adapters/inngest.js"
      },
      "require": {
        "types": "./dist/adapters/inngest.d.cts",
        "default": "./dist/adapters/inngest.cjs"
      }
    },
    "./adapters/slack": {
      "import": {
        "types": "./dist/adapters/slack.d.ts",
        "default": "./dist/adapters/slack.js"
      },
      "require": {
        "types": "./dist/adapters/slack.d.cts",
        "default": "./dist/adapters/slack.cjs"
      }
    }
  },
  "typesVersions": {
    "*": {
      "adapters/inngest": [
        "./dist/adapters/inngest.d.ts"
      ],
      "adapters/slack": [
        "./dist/adapters/slack.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check-exports": "attw --pack . && publint",
    "validate": "npm run typecheck && npm run lint && npm run test && npm run build && npm run check-exports",
    "prepare": "lefthook install",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run validate && changeset publish",
    "prepublishOnly": "npm run validate"
  },
  "peerDependencies": {
    "inngest": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "inngest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@biomejs/biome": "^2.4.11",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^22.15.2",
    "@vitest/coverage-v8": "^3.2.4",
    "inngest": "^3.31.0",
    "lefthook": "^2.1.5",
    "publint": "^0.3.12",
    "tsup": "^8.4.0",
    "typescript": "^6.0.2",
    "vitest": "^3.1.2"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/backhandvolley/posthog-flag-toolkit.git"
  },
  "keywords": [
    "posthog",
    "feature-flags",
    "feature-flag",
    "release-tracker",
    "guardian",
    "auto-rollback"
  ]
}
